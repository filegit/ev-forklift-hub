# LLM 配置模板（复制为 .env.local 后填入真实 Key，.env.local 不会提交 Git）
#
# 【本地开发】 copy .env.example .env.local  → 运行 start-agent.bat
# 【服务器部署】 copy deploy.env.example .env  → 注入 Docker / systemd（见下方说明）

LLM_ENABLED=true
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://niceapi.ai/v1
LLM_MODEL=gpt-5.4
# 阿里云百炼示例（二选一，改 base-url 和 model 即可）:
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus
# LLM_API_KEY=sk-your-dashscope-key
