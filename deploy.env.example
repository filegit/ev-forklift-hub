# ============================================================
# 服务器部署环境变量模板（复制为 .env 后填入真实值，勿提交 Git）
# 用法（Linux 服务器）:
#   cp deploy.env.example .env
#   vim .env
#   docker compose --env-file .env up -d
# ============================================================

# ---------- 基础设施 ----------
MYSQL_ROOT_PASSWORD=change-me
MYSQL_HOST=mysql
REDIS_PASSWORD=change-me
REDIS_HOST=redis
NACOS_SERVER_ADDR=nacos:8848

# ---------- AI Agent / LLM（仅 efh-agent 服务需要）----------
LLM_ENABLED=true
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://niceapi.ai/v1
LLM_MODEL=gpt-5.4

# 阿里云百炼:
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus

# ---------- 知识库文件目录（agent 与 knowledge 需能访问同一路径）----------
KNOWLEDGE_UPLOAD_DIR=/data/knowledge/uploads

# ---------- 登录短信（阿里云「号码认证-短信认证」，个人实名即可，无需企业资质）----------
# 开通: https://dypns.console.aliyun.com/  -> 短信认证 -> 赠送签名/模板
# 文档: https://help.aliyun.com/zh/pnvs/use-cases/sms-verify-for-individual-developers
SMS_MOCK=false
SMS_ACCESS_KEY_ID=your-access-key-id
SMS_ACCESS_KEY_SECRET=your-access-key-secret
SMS_SIGN_NAME=控制台复制的赠送签名
SMS_TEMPLATE_CODE=控制台复制的赠送模板CODE
SMS_REGION_ID=cn-hangzhou
