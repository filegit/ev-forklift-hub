# 支付宝支付配置示例（复制为 .env 或在启动脚本中 export）

# 启用支付宝
ALIPAY_ENABLED=true

# 沙箱 AppId（登录 https://open.alipay.com 开发助手获取）
ALIPAY_APP_ID=你的沙箱APPID

# 应用私钥 PKCS8 格式（去掉头尾和换行，或使用完整 PEM）
ALIPAY_PRIVATE_KEY=你的应用私钥

# 支付宝公钥（非应用公钥）
ALIPAY_PUBLIC_KEY=支付宝公钥

# 是否沙箱（生产环境设为 false）
ALIPAY_SANDBOX=true

# 异步通知地址（必须公网可达，本地开发可用 ngrok / natapp 映射到 80 端口）
ALIPAY_NOTIFY_URL=https://你的域名/parts/api/parts/pay/alipay/notify

# 支付完成同步跳转（前端支付结果页）
ALIPAY_RETURN_URL=http://localhost/pay/result

# 启动示例（PowerShell）:
# $env:ALIPAY_ENABLED="true"
# $env:ALIPAY_APP_ID="902100..."
# $env:ALIPAY_PRIVATE_KEY="MIIEv..."
# $env:ALIPAY_PUBLIC_KEY="MIIBI..."
# java -jar efh-parts/target/efh-parts-1.0.0.jar
